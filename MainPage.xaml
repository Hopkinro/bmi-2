<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BMICalculatorNavigationApp.Pages.MainPage"
             Title="BMI Calculator"
             BackgroundColor="#F7F7F7">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">

            <Label Text="BMI Calculator"
                   FontSize="30"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#222" />

            <Frame Padding="16" CornerRadius="18" BackgroundColor="White" HasShadow="True">
                <VerticalStackLayout Spacing="18">

                    <Label Text="Select Gender"
                           FontSize="20"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                        <Frame x:Name="MaleFrame"
                               Grid.Column="0"
                               BorderColor="Gray"
                               Padding="10"
                               CornerRadius="16"
                               BackgroundColor="#FAFAFA">
                            <VerticalStackLayout Spacing="8">
                                <Image Source="male.png"
                                       HeightRequest="120"
                                       WidthRequest="120"
                                       HorizontalOptions="Center">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnMaleTapped" />
                                    </Image.GestureRecognizers>
                                </Image>
                                <Label Text="Male"
                                       HorizontalOptions="Center"
                                       FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Frame>

                        <Frame x:Name="FemaleFrame"
                               Grid.Column="1"
                               BorderColor="Gray"
                               Padding="10"
                               CornerRadius="16"
                               BackgroundColor="#FAFAFA">
                            <VerticalStackLayout Spacing="8">
                                <Image Source="female.png"
                                       HeightRequest="120"
                                       WidthRequest="120"
                                       HorizontalOptions="Center">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnFemaleTapped" />
                                    </Image.GestureRecognizers>
                                </Image>
                                <Label Text="Female"
                                       HorizontalOptions="Center"
                                       FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>

                    <Label Text="Weight (lbs)"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Label x:Name="WeightValueLabel"
                           Text="90 lbs"
                           FontSize="17" />

                    <Slider x:Name="WeightSlider"
                            Minimum="0"
                            Maximum="300"
                            Value="90"
                            ThumbColor="#512BD4"
                            MinimumTrackColor="#512BD4"
                            ValueChanged="OnWeightSliderChanged" />

                    <Label Text="Height (inches)"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Label x:Name="HeightValueLabel"
                           Text="50 in"
                           FontSize="17" />

                    <Slider x:Name="HeightSlider"
                            Minimum="0"
                            Maximum="100"
                            Value="50"
                            ThumbColor="#512BD4"
                            MinimumTrackColor="#512BD4"
                            ValueChanged="OnHeightSliderChanged" />

                    <Button Text="Calculate BMI"
                            HeightRequest="55"
                            BackgroundColor="#512BD4"
                            TextColor="White"
                            Clicked="OnCalculateBmiClicked" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>