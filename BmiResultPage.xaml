<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BMICalculatorNavigationApp.Pages.BmiResultPage"
             Title="BMI Result"
             BackgroundColor="#F7F7F7">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">

            <Label Text="BMI Result"
                   FontSize="30"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Frame Padding="16" CornerRadius="18" BackgroundColor="White" HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="GenderLabel" FontSize="19" />
                    <Label x:Name="WeightLabel" FontSize="19" />
                    <Label x:Name="HeightLabel" FontSize="19" />
                    <Label x:Name="BmiLabel"
                           FontSize="24"
                           FontAttributes="Bold" />
                    <Label x:Name="CategoryLabel"
                           FontSize="24"
                           FontAttributes="Bold" />
                </VerticalStackLayout>
            </Frame>

            <Button Text="View Health Recommendations"
                    HeightRequest="55"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    Clicked="OnRecommendationsClicked" />

            <Button Text="Back to Input Page"
                    HeightRequest="55"
                    BackgroundColor="#D9D9D9"
                    TextColor="Black"
                    Clicked="OnBackToInputClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>